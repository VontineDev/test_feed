# ================================================================
# 뉴스 크롤러 환경변수 설정
# 이 파일을 .env 로 저장하고 값을 채운 뒤 사용하세요.
# .gitignore 에 .env 를 반드시 추가하세요.
# ================================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_db
DB_USER=news_user
DB_PASSWORD=

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── LM Studio / Ollama (기본값 그대로면 수정 불필요) ──────────
LM_STUDIO_BASE=http://localhost:1234
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
