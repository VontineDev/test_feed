# ================================================================
# 뉴스 크롤러 환경변수 설정
# 이 파일을 .env 로 저장하고 값을 채운 뒤 사용하세요.
# .gitignore 에 .env 를 반드시 추가하세요.
# ================================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_db
DB_USER=news_user
DB_PASSWORD=

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# 채널 발송 (선택) — @채널이름 또는 -100xxxx 형식. 설정 시 뉴스·신호를 채널에도 발송.
TELEGRAM_CHANNEL_ID=

# ── LM Studio / Ollama (기본값 그대로면 수정 불필요) ──────────
LM_STUDIO_BASE=http://localhost:1234
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── 매크로 컨텍스트 ──────────────────────────────────────────
# 한국은행 기준금리 — BOK 발표 시 수동 업데이트 (연 최대 8회 변경)
KOREA_BASE_RATE=2.5
