# .env.example — copy to .env and fill in real values
# .env is gitignored and must NOT be committed

# ── PostgreSQL ────────────────────────────────────────────────
# Required: no default password — set a strong unique value
DB_PASSWORD=<replace_with_strong_password>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=news_db
DB_USER=news_user

# Alternatively, use a single DATABASE_URL instead of DB_* vars:
# DATABASE_URL=postgresql://news_user:<password>@localhost:5432/news_db

# ── Telegram ─────────────────────────────────────────────────
# Required: bot token from @BotFather
TELEGRAM_TOKEN=<bot_token>

# Required: at least one of these must be set (auth bypass prevention)
# Comma-separated list of allowed chat IDs (preferred for multi-user):
ALLOWED_CHAT_IDS=<chat_id_1>,<chat_id_2>
# Or single chat ID:
# TELEGRAM_CHAT_ID=<chat_id>

# ── Korea macro data ─────────────────────────────────────────
# Update manually when BOK changes the base rate
KOREA_BASE_RATE=3.50
